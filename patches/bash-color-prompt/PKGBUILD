pkgname=bash-color-prompt
pkgrel=1
pkgdesc="Customizable color prompt for bash (bcp)"
arch=('any')
url="https://github.com/juhp/bash-color-prompt"
license=('GPL3')
depends=('bash')
makedepends=('perl')
source=("https://github.com/juhp/bash-color-prompt/archive/refs/heads/main.tar.gz")
sha256sums=('SKIP')

pkgver() {
  for d in "${srcdir}"/*bash-color-prompt* "${srcdir}"/bash-color-prompt*; do
    if [ -f "${d}/VERSION" ]; then
      cat "${d}/VERSION"
      return 0
    fi
  done
  if [ -f "${srcdir}/VERSION" ]; then
    cat "${srcdir}/VERSION"
    return 0
  fi
  echo "0.0.0"
}

prepare() {
  cd "${srcdir}/bash-color-prompt-main"
  sed -i -e 's!@BCP_LIBRARY@!/usr/share/bash-color-prompt/bcp.sh!' bcp-profile.sh
}

build() {
  cd "${srcdir}/bash-color-prompt-main"
  local pv
  pv=$(pkgver)
  sed -i -e "s/@BASHCOLORVERSION@/${pv}/" bash-color-prompt.sh
  bash -c 'source ./bash-color-prompt.sh; bcp_static _bcp_static_layout; export PS1; perl -i -pe '\''s/\@BCP_STATIC_PS1\@/$ENV{PS1}/'\'' bcp-profile.sh'
}

package() {
  cd "${srcdir}/bash-color-prompt-main"
  install -Dm644 bcp-profile.sh "${pkgdir}/etc/profile.d/bash-color-prompt.sh"
  install -Dm644 bash-color-prompt.sh "${pkgdir}/usr/share/bash-color-prompt/bcp.sh"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
  install -Dm644 example.bashrc.sh "${pkgdir}/usr/share/doc/${pkgname}/example.bashrc.sh"
}
